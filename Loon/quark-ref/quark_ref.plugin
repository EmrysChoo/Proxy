#!name=夸克播放修复
#!desc=为夸克网盘播放链接添加必要的Headers，解决412错误
#!author=Shayon

[Argument]
quark_cookie = input, "", tag=夸克Cookie, desc=夸克网盘登录Cookie

[Script]
# 为夸克播放链接添加必要的Headers
http-request ^https://video-play.*\.drive\.quark\.cn/ script-path=https://raw.githubusercontent.com/EmrysChoo/Proxy/main/Loon/quark-ref/quark_ref.js, timeout=10, argument=[{quark_cookie}], tag=夸克播放Headers

[MITM]
hostname = %APPEND%video-play-c-zb.drive.quark.cn, video-play-h-zb.drive.quark.cn, video-play-sz.drive.quark.cn
